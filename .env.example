# Legacy OpenRouter
OPENROUTER_API_KEY=your_key_here
OPENROUTER_MODEL=qwen/qwen3.6-plus

# Generic single provider
AI_GATEWAY_PROVIDER_1_NAME=cliproxy
AI_GATEWAY_PROVIDER_1_BASE_URL=http://127.0.0.1:8317/v1
AI_GATEWAY_PROVIDER_1_API_KEY=dummy
AI_GATEWAY_PROVIDER_1_MODEL=DeepSeek-V4-Pro
AI_GATEWAY_PROVIDER_1_ENABLED=true
AI_GATEWAY_PROVIDER_1_SUPPORTS_STREAMING=true

# Generic provider with key pool
AI_GATEWAY_PROVIDER_2_NAME=openrouter
AI_GATEWAY_PROVIDER_2_BASE_URL=https://openrouter.ai/api/v1
AI_GATEWAY_PROVIDER_2_MODEL=qwen/qwen3.6-plus
AI_GATEWAY_PROVIDER_2_ENABLED=true

AI_GATEWAY_PROVIDER_2_KEY_1_NAME=openrouter_main
AI_GATEWAY_PROVIDER_2_KEY_1_API_KEY=your_key_here
AI_GATEWAY_PROVIDER_2_KEY_1_ENABLED=true
AI_GATEWAY_PROVIDER_2_KEY_1_DAILY_REQUEST_LIMIT=1000
AI_GATEWAY_PROVIDER_2_KEY_1_DAILY_COST_LIMIT=1.0

# Gateway
AI_GATEWAY_HOST=127.0.0.1
AI_GATEWAY_PORT=8000
AI_GATEWAY_LOG_LEVEL=info

# Budget
AI_GATEWAY_BUDGET_MODE=normal
AI_GATEWAY_DAILY_BUDGET_USD=1.0
AI_GATEWAY_MONTHLY_BUDGET_USD=30.0
AI_GATEWAY_MAX_COST_PER_REQUEST=0.05

# Smoke / client
AI_GATEWAY_BASE_URL=http://127.0.0.1:8000/v1
AI_GATEWAY_API_KEY=dummy
AI_GATEWAY_MODEL=qwen/qwen3.6-plus

# Cache (Optional)
AI_GATEWAY_PROVIDER_1_SUPPORTS_PROMPT_CACHE=true
AI_GATEWAY_PROVIDER_1_CACHE_READ_COST_PER_MILLION=0.1
AI_GATEWAY_PROVIDER_1_CACHE_WRITE_COST_PER_MILLION=0.5
AI_GATEWAY_PROVIDER_1_CACHE_PRIORITY=1.2
